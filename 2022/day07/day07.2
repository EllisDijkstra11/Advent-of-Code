                file_index = index + 1  # Look at the files in this list
                while no_dir and file_index < len(partial_commands) - 1 and partial_commands[file_index][0] != "$":
                    print("entered first")
                    if partial_commands[index + 1][0] == "dir":
                        #print("entered false")
                        no_dir = False
                    file_index += 1

                file_index = index + 1
                directory_sum = 0
                if no_dir and file_index < len(partial_commands) - 1 and partial_commands[file_index][0] != "$":
                    changed = True

                    while file_index < len(partial_commands) and partial_commands[file_index][0] != "$":
                        #print("entered second")

                        #print(partial_commands[file_index][0])
                        directory_sum += int(partial_commands[file_index][0])
                        print(partial_commands[index])                    
                        print("first remove")                        
                        pprint(partial_command)
                        partial_command.remove(partial_commands[index])
                        pprint(partial_command)
                        file_index += 1
                    #print("directory sum", directory_sum)

                    all_sums.append(directory_sum)
                    #print("sums", all_sums)
                    for command_index in range(len(partial_command) - 1):
                        #print(partial_commands[index-1], partial_command[command_index])
                        print("replace ", partial_commands[index - 1][2], partial_command[command_index][1])
                        if partial_commands[index - 1][2] == partial_command[command_index][1]:
                            #print("Yes", command_index)
