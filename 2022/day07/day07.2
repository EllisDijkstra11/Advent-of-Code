def preprocess(input_lines: list[int]):
    files = ["/"]
    commands = input_lines.split("\n")
    current_directory = ""
    max_depth = 0
    partial_commands = []

    for command in commands:
        partial_command = command.split(" ")
        partial_commands.append(partial_command)

    while ["$", "cd", ".."] in partial_commands:
        partial_commands.remove(["$", "cd", ".."])

    while ["$", "cd", "\\"] in partial_commands:
        partial_commands.remove(["$", "cd", "\\"])
    all_sums = []

    partial_command = partial_commands.copy()
    changed = False
    no_dir = True

    # As long as there are still movements to directories, not all the directories have been summed
    while ["$", "ls"] in partial_command:
        for index in range(len(partial_commands)):  # Check single lines
            changed = False  # No changes have been made to partial_command yet

            #print("ls?", partial_commands[index])
